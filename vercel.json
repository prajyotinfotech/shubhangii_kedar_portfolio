{
    "headers": [
        {
            "source": "/assets/(.*\\.(?:png|jpg|jpeg|webp|gif|svg|ico|woff|woff2|otf|ttf))",
            "headers": [
                {
                    "key": "Cache-Control",
                    "value": "public, max-age=2592000, stale-while-revalidate=86400"
                }
            ]
        }
    ],
    "rewrites": [
        {
            "source": "/(.*)",
            "destination": "/index.html"
        }
    ]
}
